{
  "name": "secretdef-ui",
  "version": "0.0.1",
  "description": "Local dashboard for secretdef — view, check, and manage your secret definitions",
  "type": "module",
  "bin": {
    "secretdef-ui": "./dist/cli.js"
  },
  "files": [
    "dist",
    "ui-dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:ui": "vite build",
    "build:server": "tsup",
    "build": "pnpm build:ui && pnpm build:server",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "secretdef",
    "dashboard",
    "secrets",
    "env"
  ],
  "author": "felix menard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iplanwebsites/secretdef",
    "directory": "packages/secretdef-ui"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
