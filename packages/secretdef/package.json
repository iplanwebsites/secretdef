{
  "name": "secretdef",
  "version": "0.0.3",
  "description": "Declare the secrets your packages require. Fail fast with actionable errors.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./edge": {
      "import": {
        "types": "./dist/edge.d.ts",
        "default": "./dist/edge.js"
      },
      "require": {
        "types": "./dist/edge.d.cts",
        "default": "./dist/edge.cjs"
      }
    }
  },
  "bin": {
    "secretdef": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "secrets",
    "env",
    "environment",
    "validation",
    "config",
    "dotenv",
    "typescript"
  ],
  "author": "felix menard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iplanwebsites/secretdef",
    "directory": "packages/secretdef"
  },
  "homepage": "https://secretdef.com",
  "bugs": {
    "url": "https://github.com/iplanwebsites/secretdef/issues"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
