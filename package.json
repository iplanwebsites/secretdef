{
  "name": "secretdef-monorepo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/iplanwebsites/secretdef"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev --filter=secretdef-web",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && changeset publish",
    "generate-registry": "node scripts/generate-registry.mjs",
    "sync-skills": "bash scripts/sync-skills.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
